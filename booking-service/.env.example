# booking-service — modèle de variables d'environnement.
# Copier en `.env` et ajuster : `cp .env.example .env`
# Chargé automatiquement par `docker compose` (même répertoire).

# ── Base de données ────────────────────────────────────────────────
BOOKING_DB_URL=jdbc:postgresql://localhost:5435/bookingdb
BOOKING_DB_USER=bookinguser
BOOKING_DB_PASSWORD=bookingpass

# ── Keycloak : compte de service (appels sortants client_credentials) ─
# Doit correspondre au client « booking-service » du realm (realm-export.json).
KEYCLOAK_BOOKING_CLIENT_ID=booking-service
KEYCLOAK_BOOKING_SERVICE_SECRET=changeme

# ── Keycloak : joignable DEPUIS LES CONTENEURS (réseau Docker partagé) ─
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/auto-ecole/protocol/openid-connect/certs
KEYCLOAK_TOKEN_URI=http://keycloak:8080/realms/auto-ecole/protocol/openid-connect/token

# ── Services appelés (résolus via Eureka : http://<application-name>) ──
AUTH_SERVICE_URL=http://auth-service
VEHICLE_SERVICE_URL=http://vehicle-service
FINANCE_SERVICE_URL=http://finance-service

# ── Service discovery (Eureka) ─────────────────────────────────────
EUREKA_ENABLED=true
EUREKA_SERVER_URL=http://discovery-service:8761/eureka