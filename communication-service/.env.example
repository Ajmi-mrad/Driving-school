# communication-service — modèle de variables d'environnement.
# Copier en `.env` et ajuster : `cp .env.example .env`
# Chargé automatiquement par `docker compose` (même répertoire).

# ── Base de données ────────────────────────────────────────────────
COMMUNICATION_DB_NAME=communicationdb
COMMUNICATION_DB_USER=communicationuser
COMMUNICATION_DB_PASSWORD=changeme

# ── Keycloak : joignable DEPUIS LES CONTENEURS (réseau Docker partagé) ─
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/auto-ecole/protocol/openid-connect/certs

# ── Keycloak : joignable DEPUIS LE NAVIGATEUR (Swagger UI « Authorize ») ─
KEYCLOAK_AUTH_URL=http://localhost:8080/realms/auto-ecole/protocol/openid-connect/auth
KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/auto-ecole/protocol/openid-connect/token
SWAGGER_OAUTH_CLIENT_ID=auto-ecole-frontend

# ── Service discovery (Eureka) ─────────────────────────────────────
EUREKA_SERVER_URL=http://discovery-service:8761/eureka

# ── Origine autorisée pour le handshake WebSocket (front Angular) ──
FRONTEND_ORIGIN=http://localhost:4200