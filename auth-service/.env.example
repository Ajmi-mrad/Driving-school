# ---- Keycloak admin (console) ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ---- Base PostgreSQL de Keycloak ----
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak

# ---- Base PostgreSQL de l'auth-service ----
AUTH_DB_NAME=authdb
AUTH_DB_USER=authuser
AUTH_DB_PASSWORD=authpass

# ---- Client confidentiel auth-service (doit matcher realm-export.json) ----
# Récupérer le secret dans la console Keycloak : Clients > auth-service > Credentials.
KEYCLOAK_AUTH_SERVICE_SECRET=changeme

# ---- Service discovery (Eureka) ----
# Laisser à false tant qu'aucun discovery-service ne tourne. Mettre true pour enregistrer
# auth-service auprès d'Eureka (voir le bloc discovery-service commenté dans docker-compose.yml).
EUREKA_ENABLED=false
EUREKA_SERVER_URL=http://discovery-service:8761/eureka

# ---- Swagger UI ↔ Keycloak (URLs vues DEPUIS LE NAVIGATEUR) ----
# Laisser vide en local : le défaut localhost:8080 correspond à KC_HOSTNAME et est joignable
# depuis le navigateur. À surcharger uniquement si Keycloak a un hostname public (staging/prod).
# KEYCLOAK_AUTH_URL=https://auth.exemple.fr/realms/auto-ecole/protocol/openid-connect/auth
# KEYCLOAK_TOKEN_URL=https://auth.exemple.fr/realms/auto-ecole/protocol/openid-connect/token
# Client public Keycloak utilisé par le bouton « Authorize » de Swagger (PKCE).
# SWAGGER_OAUTH_CLIENT_ID=auto-ecole-frontend